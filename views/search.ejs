                  </div>
                  <div class="child-check">
                    <input type="checkbox" name="categories" id="pies" value="pies"><label for="pies">pies</label>
                    <div class="child-check">
                      <input type="checkbox" name="categories" id="pie_crust" value="pie crust"><label for="pie_crust">pie crust</label>
                    </div>
                  </div>
                </div>
                <div class="child-check">
                  <input type="checkbox" name="categories" id="macarons" value="macarons"><label for="macarons">macarons</label>
                </div>
                <div class="child-check">
                  <input type="checkbox" name="categories" id="quick_breads" value="quick breads"><label for="quick_breads">quick breads</label>
                </div>
              </div>
            </div>
          </div>
        </fieldset>
      </div>
      <div class="col results-col">
        <div id="recipeList" class="card-row">
          <% recipes.forEach((recipe)=> { %>
            <div class="card">
              <a href="recipe/<%= recipe.id %>">
                <img class="card-img" alt="photo of <%= recipe.title %>" src="/imgs/<%= recipe.imagePath %>" />
              </a>
              <div class="card-body"><p class="card-title"><%= recipe.title %></p></div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>

    <%- include("partials/footer.ejs") %>
  </div>

  <%- include("partials/scripts.ejs") %>
  </body>

</html>