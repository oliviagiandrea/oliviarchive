                  </div>
                  <div class="child-check">
                    <input type="checkbox" name="categories" id="brownies" value="brownies"><label for="brownies">brownies</label>
                  </div>
                  <div class="child-check">
                    <input type="checkbox" name="categories" id="protein_bars" value="protein bars"><label for="protein_bars">protein bars</label>
                  </div>
                </div>
                <div class="child-check">
                  <input type="checkbox" name="categories" id="cakes" value="cakes"><label for="cakes">cakes</label>
                  <div class="child-check">
                    <input type="checkbox" name="categories" id="mug_cakes" value="mug cakes"><label for="mug_cakes">mug cakes</label>
                  </div>
                </div>
                <div class="child-check">
                  <input type="checkbox" name="categories" id="choux" value="choux"><label for="choux">choux</label>
                </div>
                <div class="child-check">
                  <input type="checkbox" name="categories" id="cinnamon_rolls" value="cinnamon rolls"><label for="cinnamon_rolls">cinnamon rolls</label>
                </div>
                <div class="child-check">
                  <input type="checkbox" name="categories" id="cookies" value="cookies"><label for="cookies">cookies</label>
                </div>
                <div class="child-check">
                  <input type="checkbox" name="categories" id="frostings" value="frostings"><label for="frostings">frostings</label>
                </div>
                <div class="child-check">
                  <input type="checkbox" name="categories" id="fruit" value="fruit"><label for="fruit">fruit</label>
                  <div class="child-check">
                    <input type="checkbox" name="categories" id="cobblers" value="cobblers"><label for="cobblers">cobblers</label>
                  </div>
                  <div class="child-check">
                    <input type="checkbox" name="categories" id="crisps" value="crisps"><label for="crisps">crisps</label>
                  </div>
                  <div class="child-check">
