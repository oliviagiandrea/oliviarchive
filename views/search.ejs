<%- include("partials/head.ejs") %>

<body>
  <%- include("partials/navbar.ejs") %>
  <%- include("partials/flash.ejs") %>

  <div id="home">
    <div id="welcome">
      <h1>find a recipe</h1>
      <form id="searchForm" method="POST" action="/search">
        <div class="search-box">
          <i class="fa-solid fa-magnifying-glass search-icon"></i>
          <input type="text" name="query" id="query" placeholder="Search titles...">
        </div>
        
        <!-- <input type="submit" value="Search"> -->
      </form>
    </div>
    
    <div id="results">
      <ul id="recipeList">
        <% recipes.forEach((recipe)=> { %>
          <li><a href="recipe/<%= recipe.id %>">
              <%= recipe.title %>
          </li>
          <% }) %>
      </ul>
    </div>

    <script>
      // Define a function to render the search results as HTML
      function renderSearchResults(results) {
        const resultsDiv = document.getElementById('results');
        resultsDiv.innerHTML = '';

        if (results.length === 0) {
          resultsDiv.textContent = 'No results found';
          return;
        }

        const ul = document.createElement('ul');
        resultsDiv.appendChild(ul);

        for (const result of results) {
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = `recipe/${result.id}`;
          a.textContent = result.title;
          li.appendChild(a);
          ul.appendChild(li);
        }
      }

      // Define a function to handle the search form submission
      function handleSearchFormSubmit(event) {
        event.preventDefault();

        const searchQuery = document.getElementById('query').value;
        fetch('/search', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ query: searchQuery })
        })
          .then(response => response.json())
          .then(renderSearchResults)
          .catch(error => console.error(error));
      }


      // Attach an event listener to the search form
      document.getElementById('searchForm').addEventListener('submit', handleSearchFormSubmit);
    </script>

    <%- include("partials/footer.ejs") %>
  </body>

</html>