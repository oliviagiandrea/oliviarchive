<%- include("partials/head.ejs") %>

<body>
  <%- include("partials/navbar.ejs") %>
  <%- include("partials/flash.ejs") %>

  <div class="container">
    <div id="home">
      <div id="welcome">
        <h1>find a recipe</h1>
        <form id="searchForm" method="POST" action="/home-search">
          <div class="search-box">
            <i class="fa-solid fa-magnifying-glass search-icon"></i>
            <input type="text" name="query" id="query" placeholder="Search titles...">
          </div>
        </form>
        <a class="purple" href="/search">advanced search &#62;</a>
      </div>
    </div>
    <div id="searchIng" class="row center">
      <h3><a href="/ingredients">search recipes by ingredient &#62;</a></h3>
    </div>
    <div class="container newest center">
      <h1>Newest Recipes</h1>
      <div class="card-row">
        <% recipes.slice(-5).forEach((recipe)=> { %>
          <div class="card">
            <a href="recipe/<%= recipe.id %>">
              <img class="card-img" alt="photo of <%= recipe.title %>" src="/imgs/<%= recipe.imagePath %>" />
            </a>
            <div class="card-body"><p class="card-title"><%= recipe.title %></p></div>
          </div>
        <% }) %>
      </div>
    </div>
    <div class="row email center">
      <h2 class="white">sign up for my newsletter</h2>
      <form id="email-form" method="POST" target="_blank" action="https://azurewebsites.us21.list-manage.com/subscribe/post?u=35c3928f32114cf195b23f859&amp;id=52636556da&amp;f_id=00e259e1f0">
        <div class="email-box">
          <i class="fa-solid fa-magnifying-glass email-icon"></i>
          <input type="email" name="EMAIL" id="mce-EMAIL" placeholder="your email address" required>
          <input type="submit" value="sign up" name="subscribe" id="mc-embedded-subscribe" class="btn btnGhost">
        </div>
      </form>
      <script type='text/javascript'>(function($) {window.fnames = new Array(); window.ftypes = new Array();fnames[0]='EMAIL';ftypes[0]='email';fnames[1]='FNAME';ftypes[1]='text';fnames[2]='LNAME';ftypes[2]='text';fnames[3]='ADDRESS';ftypes[3]='address';fnames[4]='PHONE';ftypes[4]='phone';fnames[5]='BIRTHDAY';ftypes[5]='birthday';}(jQuery));var $mcj = jQuery.noConflict(true);</script>
    </div>
    <div class="container categories center">
      <h1>all recipe categories</h1>
      <div class="card-row">
        <div class="card">
          <a href="/search">
            <img class="card-img" alt="photo of pancakes" src="/pancakes.jpg" />
          </a>
          <div class="card-body"><p class="card-title">breakfast</p></div>
        </div>
        <div class="card">
          <a href="/search">
            <img class="card-img" alt="photo of chicken" src="/pancakes.jpg" />
          </a>
          <div class="card-body"><p class="card-title">mains</p></div>
        </div>
        <div class="card">
          <a href="/search">
            <img class="card-img" alt="photo of green beans" src="/pancakes.jpg" />
          </a>
          <div class="card-body"><p class="card-title">sides</p></div>
        </div>
        <div class="card">
          <a href="/search">
            <img class="card-img" alt="photo of bread" src="/pancakes.jpg" />
          </a>
          <div class="card-body"><p class="card-title">bread</p></div>
        </div>
        <div class="card">
          <a href="/search">
            <img class="card-img" alt="photo of blueberry muffins" src="/pancakes.jpg" />
          </a>
          <div class="card-body"><p class="card-title">dessert</p></div>
        </div>
      </div>
      <a class="btn btnPrimary" href="/search">explore all recipes</a>
    </div>
    <footer>
      <div class="col">
        <img class="logo" alt="oliviarchive logo" src="logo.png" />
      </div>
      <div class="col">
        <h2 class="white">sign up for my newsletter</h2>
        <form id="email-form" method="POST" target="_blank" action="https://azurewebsites.us21.list-manage.com/subscribe/post?u=35c3928f32114cf195b23f859&amp;id=52636556da&amp;f_id=00e259e1f0">
          <div class="email-box">
            <i class="fa-solid fa-magnifying-glass email-icon"></i>
            <input type="email" name="EMAIL" id="mce-EMAIL" placeholder="your email address" required>
            <input type="submit" value="sign up" name="subscribe" id="mc-embedded-subscribe" class="btn btnGhost">
          </div>
        </form>
        <script type='text/javascript'>(function($) {window.fnames = new Array(); window.ftypes = new Array();fnames[0]='EMAIL';ftypes[0]='email';fnames[1]='FNAME';ftypes[1]='text';fnames[2]='LNAME';ftypes[2]='text';fnames[3]='ADDRESS';ftypes[3]='address';fnames[4]='PHONE';ftypes[4]='phone';fnames[5]='BIRTHDAY';ftypes[5]='birthday';}(jQuery));var $mcj = jQuery.noConflict(true);</script>
      </div>
      <div class="col">
        <a href="youtube.com" target="_blank">youtube</a>
      </div>
    </footer>
  </div>
    
  <!-- <div id="results">
    <ul id="recipeList">
      <% recipes.forEach((recipe)=> { %>
        <li><a href="recipe/<%= recipe.id %>">
            <%= recipe.title %>
        </li>
        <% }) %>
    </ul>
  </div> -->

  <%- include("partials/footer.ejs") %>
  </body>

</html>